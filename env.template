# Copy this file to .env and configure with your values

# GCP Configuration
GCP_PROJECT_ID=icc-project-472009
GCS_BUCKET=jaccueille
GCS_RAW_PREFIX=raw
GCS_DELTA_PREFIX=delta

# API Configuration - REQUIRED
# Generate a strong secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=REPLACE_WITH_STRONG_SECRET_DO_NOT_USE_DEFAULT

# Environment (development, staging, production)
ENVIRONMENT=development

# CORS Configuration
# Comma-separated list of allowed origins (use "*" only for development)
# Production example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Optional: Database URL for metadata (if not using in-memory)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

